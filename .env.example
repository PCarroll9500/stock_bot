# Environment configuration for Stock Trading Bot

# OpenAI API
OPENAI_API_KEY=

# Interactive Brokers (IB) API
IB_USERNAME=
IB_PASSWORD=
IB_ACCOUNT_LIVE=
IB_ACCOUNT_PAPER=
IB_HOST=
IB_PORT_PAPER=4002
IB_PORT_LIVE=4001
IB_CLIENT_ID=1
IB_EXCHANGE=SMART
IB_CURRENCY=USD
IB_MODE=paper

# Logging configuration
LOG_LEVEL=INFO          # or DEBUG / WARNING / ERROR
LOG_FILE=logs/stock_bot.log